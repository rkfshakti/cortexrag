# ── Local LLM API ────────────────────────────────────────────────────────────
# Base URL of your locally running LLM server (e.g. LM Studio on port 1234)
AGENTIC_RAG_LLM_BASE_URL=http://192.168.68.113:1234

# Model identifier passed to the API
AGENTIC_RAG_LLM_MODEL=qwen3.5-4b

# Default system prompt for the assistant
AGENTIC_RAG_LLM_SYSTEM_PROMPT=You are a helpful AI assistant with access to a knowledge base. Answer concisely and accurately using the provided context when available.

# HTTP request timeout in seconds
AGENTIC_RAG_LLM_TIMEOUT=60

# ── RAG ───────────────────────────────────────────────────────────────────────
# Path to persist the ChromaDB vector store
AGENTIC_RAG_VECTOR_STORE_PATH=./data/chroma_db

# HuggingFace sentence-transformers model for embeddings
AGENTIC_RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Text chunk size (in characters) for document splitting
AGENTIC_RAG_CHUNK_SIZE=512

# Overlap between consecutive chunks
AGENTIC_RAG_CHUNK_OVERLAP=64

# Number of documents to retrieve per query
AGENTIC_RAG_RETRIEVAL_TOP_K=3

# Minimum similarity score threshold (0.0 – 1.0)
AGENTIC_RAG_SIMILARITY_THRESHOLD=0.3

# ── STT ───────────────────────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
AGENTIC_RAG_WHISPER_MODEL=base

# Compute device: cpu | cuda
AGENTIC_RAG_WHISPER_DEVICE=cpu

# Quantisation: int8 | float16 | float32
AGENTIC_RAG_WHISPER_COMPUTE_TYPE=int8

# ── TTS ───────────────────────────────────────────────────────────────────────
# Edge TTS voice (run `edge-tts --list-voices` to see all options)
AGENTIC_RAG_TTS_VOICE=en-US-AriaNeural

# Speech rate adjustment, e.g. +10% or -5%
AGENTIC_RAG_TTS_RATE=+0%

# Speech volume adjustment, e.g. +10% or -5%
AGENTIC_RAG_TTS_VOLUME=+0%

# ── Audio Recording ───────────────────────────────────────────────────────────
# Sample rate in Hz
AGENTIC_RAG_AUDIO_SAMPLE_RATE=16000

# Seconds of silence before recording stops (voice activity detection)
AGENTIC_RAG_AUDIO_SILENCE_DURATION=2.0

# Maximum single recording length in seconds (safety cap)
AGENTIC_RAG_AUDIO_MAX_DURATION=30

# ── NVIDIA NIM API (optional — only needed for _test_nvidia.py / cloud LLM) ──
# Obtain your key at https://build.nvidia.com  (click your avatar → API Keys)
# NEVER commit a real key here — this file is safe to commit as a template
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE
